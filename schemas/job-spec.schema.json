{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/uts-compute/job-spec.schema.json",
  "title": "UTS Computing Job Spec",
  "type": "object",
  "required": ["run_id", "profile_id", "platform", "experiment", "resources", "command"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9][A-Za-z0-9_.-]{2,127}$"
    },
    "profile_id": { "type": "string" },
    "platform": {
      "type": "string",
      "enum": ["uts-hpc", "uts-ihpc"]
    },
    "experiment": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "job_type": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "properties": {
        "queue": { "type": "string" },
        "node_family": { "type": "string" },
        "ncpus": { "type": "integer", "minimum": 1 },
        "memory_gb": { "type": "integer", "minimum": 1 },
        "walltime": {
          "type": "string",
          "pattern": "^[0-9]{1,3}:[0-5][0-9]:[0-5][0-9]$"
        },
        "ngpus": { "type": "integer", "minimum": 0 },
        "array": {
          "type": "object",
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "integer", "minimum": 0 },
            "end": { "type": "integer", "minimum": 0 },
            "max_concurrent": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "command": { "type": "string" },
    "workdir": { "type": "string" },
    "inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "resumable": {
      "type": "object",
      "required": ["checkpoint_path", "resume_flag"],
      "properties": {
        "checkpoint_path": { "type": "string" },
        "resume_flag": { "type": "string" }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
