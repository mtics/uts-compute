{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/uts-compute/transfer-plan.schema.json",
  "title": "UTS Computing Transfer Plan",
  "type": "object",
  "required": ["run_id", "profile_id", "direction", "source", "destination"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9][A-Za-z0-9_.-]{2,127}$"
    },
    "profile_id": { "type": "string" },
    "direction": {
      "type": "string",
      "enum": ["upload", "download"]
    },
    "source": { "type": "string" },
    "destination": { "type": "string" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./-]+$"
      }
    },
    "max_total_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50000000000
    }
  },
  "additionalProperties": false
}
