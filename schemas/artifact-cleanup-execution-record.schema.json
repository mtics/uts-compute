{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/uts-compute/artifact-cleanup-execution-record.schema.json",
  "title": "UTS Computing Artifact Cleanup Execution Record",
  "type": "object",
  "required": ["run_id", "profile_id", "platform", "approval_id", "kind", "observed_at", "evidence"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "run_id": { "type": "string" },
    "profile_id": { "type": "string" },
    "platform": {
      "type": "string",
      "enum": ["uts-hpc", "uts-ihpc"]
    },
    "approval_id": {
      "type": "string",
      "pattern": "^approval-[A-Za-z0-9_.:-]{1,220}$"
    },
    "kind": { "const": "cleanup-execute" },
    "observed_at": { "type": "string", "format": "date-time" },
    "evidence": {
      "type": "object",
      "required": [
        "manifest_hash",
        "artifact_ids",
        "remote_deleted_files",
        "remote_missing",
        "remote_total_deleted_bytes",
        "local_deleted_files",
        "command"
      ],
      "properties": {
        "manifest_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "type": "string",
            "pattern": "^artifact-[a-f0-9]{24}$"
          }
        },
        "remote_deleted_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "remote_missing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "remote_total_deleted_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "local_deleted_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "command": {
          "type": "object",
          "required": ["program", "args", "remote_argv"],
          "properties": {
            "program": { "const": "ssh" },
            "args": {
              "type": "array",
              "items": { "type": "string" }
            },
            "remote_argv": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
