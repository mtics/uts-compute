{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/uts-compute/planned-transfer.schema.json",
  "title": "UTS Computing Planned Transfer Artifact",
  "type": "object",
  "required": [
    "mode",
    "run_id",
    "profile_id",
    "platform",
    "direction",
    "plan_hash",
    "source",
    "destination",
    "script",
    "warnings"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "mode": { "const": "dry-run" },
    "run_id": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9][A-Za-z0-9_.-]{2,127}$"
    },
    "profile_id": { "type": "string" },
    "platform": {
      "type": "string",
      "enum": ["uts-hpc", "uts-ihpc"]
    },
    "direction": {
      "type": "string",
      "enum": ["upload", "download"]
    },
    "plan_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "quota_snapshot_id": { "type": "string" },
    "source": { "type": "string" },
    "destination": { "type": "string" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./-]+$"
      }
    },
    "max_total_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50000000000
    },
    "script": {
      "type": "string",
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plan_path": { "type": "string" }
  },
  "additionalProperties": false
}
