{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/uts-compute/docs-cache-record.schema.json",
  "title": "UTS Documentation Cache Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "title",
    "source_url",
    "observed_at",
    "status_code",
    "content_type",
    "bytes",
    "text_chars",
    "content_hash",
    "text",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 500
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status_code": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "content_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "bytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2000000
    },
    "text_chars": {
      "type": "integer",
      "minimum": 0
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "etag": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "last_modified": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "text": {
      "type": "string",
      "maxLength": 3000000
    },
    "warnings": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}
