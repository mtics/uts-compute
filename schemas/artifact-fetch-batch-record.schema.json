{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/uts-compute/artifact-fetch-batch-record.schema.json",
  "title": "UTS Computing Artifact Batch Fetch Record",
  "type": "object",
  "required": ["run_id", "profile_id", "platform", "kind", "observed_at", "evidence"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.1.0"] },
    "run_id": { "type": "string" },
    "profile_id": { "type": "string" },
    "platform": {
      "type": "string",
      "enum": ["uts-hpc", "uts-ihpc"]
    },
    "approval_id": {
      "type": "string",
      "pattern": "^approval-[A-Za-z0-9_.:-]{1,220}$"
    },
    "kind": { "const": "fetch-batch" },
    "observed_at": { "type": "string", "format": "date-time" },
    "evidence": {
      "type": "object",
      "required": [
        "artifact_ids",
        "manifest_hash",
        "max_bytes_per_file",
        "max_total_bytes",
        "total_size_bytes",
        "files"
      ],
      "properties": {
        "approval_id": {
          "type": "string",
          "pattern": "^approval-[A-Za-z0-9_.:-]{1,220}$"
        },
        "artifact_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "type": "string",
            "pattern": "^artifact-[a-f0-9]{24}$"
          }
        },
        "manifest_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "max_bytes_per_file": {
          "type": "integer",
          "minimum": 1
        },
        "max_total_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact_id", "artifact_path", "local_path", "size_bytes", "sha256", "command"],
            "properties": {
              "artifact_id": {
                "type": "string",
                "pattern": "^artifact-[a-f0-9]{24}$"
              },
              "artifact_path": { "type": "string" },
              "local_path": { "type": "string" },
              "size_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "command": {
                "type": "object",
                "required": ["program", "args", "remote_argv"],
                "properties": {
                  "program": { "const": "ssh" },
                  "args": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "remote_argv": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
